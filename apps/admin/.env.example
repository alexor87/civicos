# Supabase — same project as apps/web
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — required for admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Impersonation — shared secret between admin & web apps
IMPERSONATION_SECRET=your-impersonation-secret

# URL of the web app (for impersonation redirects)
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000
